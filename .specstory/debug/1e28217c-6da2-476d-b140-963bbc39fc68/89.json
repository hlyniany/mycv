c questions based on gaps or ambiguities]\\n\\n---\\n\\n**Job description:**\\n[PASTE JOB DESCRIPTION HERE]',\n            ua: 'Ти — експерт з технічного рекрутингу та аналізу резюме.\\n\\nЯ надам тобі:\\n1. JSON Resume (за URL нижче)\\n2. Опис вакансії (вставлю після цього промту)\\n\\n**URL резюме у форматі JSON:** ' + RESUME_URL + '\\n\\n**Твоє завдання:**\\n1. Завантажити та розпарсити JSON Resume за вказаним URL\\n2. Прочитати опис вакансії, який я вставлю нижче\\n3. Проаналізувати відповідність профілю кандидата та вимог ролі\\n4. Сформувати структурований звіт:\\n\\n---\\n## Аналіз відповідності\\n\\n### ✅ Сильні збіги\\n[Навички, досвід, ключові слова, які прямо відповідають вимогам]\\n\\n### ⚠️ Часткові збіги\\n[Сфери, де кандидат має суміжний, але не точний досвід]\\n\\n### ❌ Прогалини\\n[Вимоги, які не покриті резюме]\\n\\n### 🏆 Загальна оцінка відповідності\\n[X/10 з одним реченням обґрунтування]\\n\\n### 💬 Рекомендовані питання для скринінгового дзвінка\\n[3–5 конкретних питань на основі прогалин або неоднозначностей]\\n\\n---\\n\\n**Опис вакансії:**\\n[ВСТАВТЕ ОПИС ВАКАНСІЇ ТУТ]'\n        };\n        var currentLang = 'en';\n        var isOpen = false;\n        var closeTimer = null;\n\n        document.getElementById('banner-prompt-pre').textContent = PROMPTS['en'];\n\n        function openBanner() {\n            if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }\n            if (isOpen) return;\n            isOpen = true;\n            document.getElementById('banner-panel').classList.add('open');\n            document.getElementById('banner-arrow').classList.add('open');\n            document.getElementById('banner-btn').setAttribute('aria-expanded', 'true');\n            document.getElementById('banner-spacer').style.height = (44 + Math.round(window.innerHeight * 0.4)) + 'px';\n        }\n\n        function closeBanner() {\n            if (!isOpen) return;\n            isOpen = false;\n            document.getElementById('banner-panel').classList.remove('open');\n            document.getElementById('banner-arrow').classList.remove('open');\n            document.getElementById('banner-btn').setAttribute('aria-expanded', 'false');\n            document.getElementById('banner-spacer').style.height = '44px';\n        }\n\n        document.getElementById('recruiter-banner').addEventListener('mouseenter', openBanner);\n        document.getElementById('recruiter-banner').addEventListener('mouseleave', function () {\n            closeTimer = setTimeout(closeBanner, 150);\n        });\n\n        window.bannerToggle = function () { isOpen ? closeBanner() : openBanner(); };\n        window.bannerClose  = function () { closeBanner(); };\n\n        window.bannerSetLang = function (lang) {\n            currentLang = lang;\n            var pre = document.getElementById('banner-prompt-pre');\n            pre.style.opacity = '0';\n            setTimeout(function () { pre.textContent = PROMPTS[lang]; pre.style.opacity = '1'; }, 120);\n            document.getElementById('bbtn-en').classList.toggle('active', lang === 'en');\n            document.getElementById('bbtn-ua').classList.toggle('active', lang === 'ua');\n        };\n\n        window.bannerCopy = function () {\n            var iconSlot = document.getElementById('banner-copy-icon');\n            var text = document.getElementById('banner-copy-text');\n            navigator.clipboard.writeText(PROMPTS[currentLang]).then(function () {\n                iconSlot.outerHTML = '\u003csvg id=\"banner-copy-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\u003e\u003cpolyline points=\"20 6 9 17 4 12\"/\u003e\u003c/svg\u003e';\n                text.textContent = 'Copied!';\n                setTimeout(function () {\n                    document.getElementById('banner-copy-icon').outerHTML = '\u003csvg id=\"banner-copy-icon\" width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\u003e\u003crect x=\"9\" y=\"9\" width=\"13\" height=\"13\" rx=\"2\"/\u003e\u003cpath d=\"M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1\"/\u003e\u003c/svg\u003e';\n                    text.textContent = 'Copy prompt';\n                }, 2000);\n            });\n        };\n    })();\n    \u003c/script\u003e",

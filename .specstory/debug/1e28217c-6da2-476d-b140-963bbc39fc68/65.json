довані питання для скринінгового дзвінка\\n[3–5 конкретних питань на основі прогалин або неоднозначностей]\\n\\n---\\n\\n**Опис вакансії:**\\n[ВСТАВТЕ ОПИС ВАКАНСІЇ ТУТ]'\n        };\n\n        var currentLang = 'en';\n        var isOpen = false;\n\n        function init() {\n            document.getElementById('banner-prompt-area').textContent = PROMPTS['en'];\n        }\n\n        window.toggleBanner = function () {\n            isOpen = !isOpen;\n            var panel = document.getElementById('banner-panel');\n            var arrow = document.getElementById('banner-arrow');\n            var hint = document.getElementById('banner-hint');\n            var body = document.body;\n\n            panel.classList.toggle('open', isOpen);\n            arrow.style.transform = isOpen ? 'rotate(180deg)' : '';\n            hint.textContent = isOpen ? 'Click to collapse' : 'Click to expand';\n\n            var stripH = document.getElementById('banner-strip').offsetHeight;\n            var panelH = isOpen ? Math.round(window.innerHeight * 0.33) : 0;\n            body.style.paddingTop = (stripH + panelH + 4) + 'px';\n        };\n\n        window.bannerSetLang = function (lang) {\n            currentLang = lang;\n            document.getElementById('banner-prompt-area').textContent = PROMPTS[lang];\n            document.getElementById('bbtn-en').classList.toggle('active', lang === 'en');\n            document.getElementById('bbtn-ua').classList.toggle('active', lang === 'ua');\n        };\n\n        window.bannerCopy = function () {\n            var btn = document.getElementById('banner-copy-btn');\n            var icon = document.getElementById('banner-copy-icon');\n            var text = document.getElementById('banner-copy-text');\n            navigator.clipboard.writeText(PROMPTS[currentLang]).then(function () {\n                btn.classList.add('copied');\n                icon.textContent = '✅';\n                text.textContent = 'Copied!';\n                setTimeout(function () {\n                    btn.classList.remove('copied');\n                    icon.textContent = '📋';\n                    text.textContent = 'Copy Prompt';\n                }, 2200);\n            });\n        };\n\n        init();\n    })();\n    \u003c/script\u003e\n\n    \u003c!-- Header --\u003e",

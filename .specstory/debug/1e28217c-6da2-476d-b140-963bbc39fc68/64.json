          "new_string": "\u003cbody style=\"font-family: Arial, sans-serif; font-size: 14px; color: #000; line-height: 1.4; margin: 0; padding: 20px;\"\u003e\n\n    \u003c!-- ── Recruiter Banner ── --\u003e\n    \u003cdiv id=\"recruiter-banner\"\u003e\n        \u003cdiv id=\"banner-strip\"\u003e\n            \u003cspan id=\"banner-cta\"\u003e▸ Analyze with AI\u003c/span\u003e\n            \u003cspan id=\"banner-chevron\"\u003e⌄\u003c/span\u003e\n        \u003c/div\u003e\n        \u003cdiv id=\"banner-panel\"\u003e\n            \u003cdiv id=\"banner-inner\"\u003e\n                \u003cdiv id=\"banner-toolbar\"\u003e\n                    \u003cbutton class=\"blang-btn active\" id=\"bbtn-en\" onclick=\"bannerSetLang('en')\"\u003eEN\u003c/button\u003e\n                    \u003cbutton class=\"blang-btn\" id=\"bbtn-ua\" onclick=\"bannerSetLang('ua')\"\u003eUA\u003c/button\u003e\n                    \u003cbutton id=\"banner-copy-btn\" onclick=\"bannerCopy()\"\u003e\n                        \u003cspan id=\"banner-copy-icon\"\u003e📋\u003c/span\u003e\n                        \u003cspan id=\"banner-copy-text\"\u003eCopy prompt\u003c/span\u003e\n                    \u003c/button\u003e\n                \u003c/div\u003e\n                \u003cdiv id=\"banner-prompt-area\"\u003e\u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n    \u003cdiv id=\"banner-spacer\"\u003e\u003c/div\u003e\n\n    \u003cscript\u003e\n    (function () {\n        var RESUME_URL = 'https://hlyniany.github.io/mycv/cv.resume.json';\n        var PROMPTS = {\n            en: 'You are an expert technical recruiter assistant and resume analyst.\\n\\nI will provide you with:\\n1. A JSON Resume (fetched from URL below)\\n2. A job description (I will paste it after this prompt)\\n\\n**Resume JSON URL:** ' + RESUME_URL + '\\n\\n**Your task:**\\n1. Fetch and parse the JSON Resume from the URL above\\n2. Read the job description I paste below\\n3. Analyze the match between the candidate\\'s profile and the role\\n4. Output a structured report:\\n\\n---\\n## Match Analysis\\n\\n### ✅ Strong matches\\n[Skills, experience, keywords that directly align]\\n\\n### ⚠️ Partial matches\\n[Areas where candidate has adjacent but not exact experience]\\n\\n### ❌ Gaps\\n[Requirements not covered by the resume]\\n\\n### 🏆 Overall fit score\\n[X/10 with one-sentence rationale]\\n\\n### 💬 Suggested talking points for screening call\\n[3–5 specific questions based on gaps or ambiguities]\\n\\n---\\n\\n**Job description:**\\n[PASTE JOB DESCRIPTION HERE]',\n            ua: 'Ти — експерт з технічного рекрутингу та аналізу резюме.\\n\\nЯ надам тобі:\\n1. JSON Resume (за URL нижче)\\n2. Опис вакансії (вставлю після цього промту)\\n\\n**URL резюме у форматі JSON:** ' + RESUME_URL + '\\n\\n**Твоє завдання:**\\n1. Завантажити та розпарсити JSON Resume за вказаним URL\\n2. Прочитати опис вакансії, який я вставлю нижче\\n3. Проаналізувати відповідність профілю кандидата та вимог ролі\\n4. Сформувати структурований звіт:\\n\\n---\\n## Аналіз відповідності\\n\\n### ✅ Сильні збіги\\n[Навички, досвід, ключові слова, які прямо відповідають вимогам]\\n\\n### ⚠️ Часткові збіги\\n[Сфери, де кандидат має суміжний, але не точний досвід]\\n\\n### ❌ Прогалини\\n[Вимоги, які не покриті резюме]\\n\\n### 🏆 Загальна оцінка відповідності\\n[X/10 з одним реченням обґрунтування]\\n\\n### 💬 Рекомендовані питання для скринінгового дзвінка\\n[3–5 конкретних питань на основі прогалин або неоднозначностей]\\n\\n---\\n\\n**Опис вакансії:**\\n[ВСТАВТЕ ОПИС ВАКАНСІЇ ТУТ]'\n        };\n        var currentLang = 'en';\n\n        document.getElementById('banner-prompt-area').textContent = PROMPTS['en'];\n\n        window.bannerSetLang = function (lang) {\n            currentLang = lang;\n            document.getElementById('banner-prompt-area').textContent = PROMPTS[lang];\n            document.getElementById('bbtn-en').classList.toggle('active', lang === 'en');\n            document.getElementById('bbtn-ua').classList.toggle('active', lang === 'ua');\n        };\n\n        window.bannerCopy = function () {\n            var icon = document.getElementById('banner-copy-icon');\n            var text = document.getElementById('banner-copy-text');\n            var btn  = document.getElementById('banner-copy-btn');\n            navigator.clipboard.writeText(PROMPTS[currentLang]).then(function () {\n                btn.classList.add('copied');\n                icon.textContent = '✓';\n                text.textContent = 'Copied!';\n                setTimeout(function () {\n                    btn.classList.remove('copied');\n                    icon.textContent = '📋';\n                    text.textContent = 'Copy prompt';\n                }, 2200);\n            });\n        };\n    })();\n    \u003c/script\u003e\n\n    \u003c!-- Header --\u003e",
          "old_string": "\u003cbody style=\"font-family: Arial, sans-serif; font-size: 14px; color: #000; line-height: 1.4; margin: 0; padding: 20px; padding-top: 58px;\"\u003e\n\n    \u003c!-- ── Recruiter Banner ── --\u003e\n    \u003cdiv id=\"recruiter-banner\"\u003e\n        \u003cdiv id=\"banner-strip\" onclick=\"toggleBanner()\"\u003e\n            \u003cdiv id=\"banner-strip-left\"\u003e\n                \u003cspan id=\"banner-strip-icon\"\u003e🎯\u003c/span\u003e\n                \u003cspan id=\"banner-strip-title\"\u003eFOR RECRUITERS\u003c/span\u003e\n                \u003cspan id=\"banner-strip-sub\"\u003e— AI Resume Analysis Prompt\u003c/span\u003e\n            \u003c/div\u003e\n            \u003cdiv id=\"banner-strip-right\"\u003e\n                \u003cspan id=\"banner-hint\"\u003eClick to expand\u003c/span\u003e\n                \u003cspan id=\"banner-arrow\"\u003e▼\u003c/span\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n        \u003cdiv id=\"banner-panel\"\u003e\n            \u003cdiv id=\"banner-inner\"\u003e\n                \u003cdiv id=\"banner-toolbar\"\u003e\n                    \u003cspan id=\"banner-toolbar-label\"\u003eLanguage\u003c/span\u003e\n                    \u003cbutton class=\"blang-btn active\" id=\"bbtn-en\" onclick=\"bannerSetLang('en'); event.stopPropagation()\"\u003eEN\u003c/button\u003e\n                    \u003cbutton class=\"blang-btn\" id=\"bbtn-ua\" onclick=\"bannerSetLang('ua'); event.stopPropagation()\"\u003eUA\u003c/button\u003e\n                    \u003cbutton id=\"banner-copy-btn\" onclick=\"bannerCopy(); event.stopPropagation()\"\u003e\n                        \u003cspan id=\"banner-copy-icon\"\u003e📋\u003c/span\u003e\n                        \u003cspan id=\"banner-copy-text\"\u003eCopy Prompt\u003c/span\u003e\n                    \u003c/button\u003e\n                \u003c/div\u003e\n                \u003cdiv id=\"banner-prompt-area\"\u003e\u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cscript\u003e\n    (function () {\n        var RESUME_URL = 'https://hlyniany.github.io/mycv/cv.resume.json';\n\n        var PROMPTS = {\n            en: 'You are an expert technical recruiter assistant and resume analyst.\\n\\nI will provide you with:\\n1. A JSON Resume (fetched from URL below)\\n2. A job description (I will paste it after this prompt)\\n\\n**Resume JSON URL:** ' + RESUME_URL + '\\n\\n**Your task:**\\n1. Fetch and parse the JSON Resume from the URL above\\n2. Read the job description I paste below\\n3. Analyze the match between the candidate\\'s profile and the role\\n4. Output a structured report:\\n\\n---\\n## Match Analysis\\n\\n### ✅ Strong matches\\n[Skills, experience, keywords that directly align]\\n\\n### ⚠️ Partial matches\\n[Areas where candidate has adjacent but not exact experience]\\n\\n### ❌ Gaps\\n[Requirements not covered by the resume]\\n\\n### 🏆 Overall fit score\\n[X/10 with one-sentence rationale]\\n\\n### 💬 Suggested talking points for screening call\\n[3–5 specific questions based on gaps or ambiguities]\\n\\n---\\n\\n**Job description:**\\n[PASTE JOB DESCRIPTION HERE]',\n            ua: 'Ти — експерт з технічного рекрутингу та аналізу резюме.\\n\\nЯ надам тобі:\\n1. JSON Resume (за URL нижче)\\n2. Опис вакансії (вставлю після цього промту)\\n\\n**URL резюме у форматі JSON:** ' + RESUME_URL + '\\n\\n**Твоє завдання:**\\n1. Завантажити та розпарсити JSON Resume за вказаним URL\\n2. Прочитати опис вакансії, який я вставлю нижче\\n3. Проаналізувати відповідність профілю кандидата та вимог ролі\\n4. Сформувати структурований звіт:\\n\\n---\\n## Аналіз відповідності\\n\\n### ✅ Сильні збіги\\n[Навички, досвід, ключові слова, які прямо відповідають вимогам]\\n\\n### ⚠️ Часткові збіги\\n[Сфери, де кандидат має суміжний, але не точний досвід]\\n\\n### ❌ Прогалини\\n[Вимоги, які не покриті резюме]\\n\\n### 🏆 Загальна оцінка відповідності\\n[X/10 з одним реченням обґрунтування]\\n\\n### 💬 Рекомендовані питання для скринінгового дзвінка\\n[3–5 конкретних питань на основі прогалин або неоднозначностей]\\n\\n---\\n\\n**Опис вакансії:**\\n[ВСТАВТЕ ОПИС ВАКАНСІЇ ТУТ]'\n        };\n\n        var currentLang = 'en';\n        var isOpen = false;\n\n        function init() {\n            document.getElementById('banner-prompt-area').textContent = PROMPTS['en'];\n        }\n\n        window.toggleBanner = function () {\n            isOpen = !isOpen;\n            var panel = document.getElementById('banner-panel');\n            var arrow = document.getElementById('banner-arrow');\n            var hint = document.getElementById('banner-hint');\n            var body = document.body;\n\n            panel.classList.toggle('open', isOpen);\n            arrow.style.transform = isOpen ? 'rotate(180deg)' : '';\n            hint.textContent = isOpen ? 'Click to collapse' : 'Click to expand';\n\n            var stripH = document.getElementById('banner-strip').offsetHeight;\n            var panelH = isOpen ? Math.round(window.innerHeight * 0.33) : 0;\n            body.style.paddingTop = (stripH + panelH + 4) + 'px';\n        };\n\n        window.bannerSetLang = function (lang) {\n            currentLang = lang;\n            document.getElementById('banner-prompt-area').textContent = PROMPTS[lang];\n            document.getElementById('bbtn-en').classList.toggle('active', lang === 'en');\n            document.getElementById('bbtn-ua').classList.toggle('active', lang === 'ua');\n        };\n\n        window.bannerCopy = function () {\n            var btn = document.getElementById('banner-copy-btn');\n            var icon = document.getElementById('banner-copy-icon');\n            var text = document.getElementById('banner-copy-text');\n            navigator.clipboard.writeText(PROMPTS[currentLang]).then(function () {\n                btn.classList.add('copied');\n                icon.textContent = '✅';\n                text.textContent = 'Copied!';\n                setTimeout(function () {\n                    btn.classList.remove('copied');\n                    icon.textContent = '📋';\n                    text.textContent = 'Copy Prompt';\n                }, 2200);\n            });\n        };\n\n        init();\n    })();\n    \u003c/script\u003e\n\n    \u003c!-- Header --\u003e",
